{
  "name": "aggy",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "oxlint src/ scripts/ vite.config.ts",
    "lint:fix": "oxlint --fix src/ scripts/ vite.config.ts",
    "fmt": "oxfmt src/ scripts/ vite.config.ts index.html",
    "fmt:check": "oxfmt --check src/ scripts/ vite.config.ts index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run fmt:check && pnpm run lint && tsc --noEmit",
    "bench:gen": "tsx bench/generate.ts",
    "bench": "tsx bench/run.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev18.0",
    "chart.js": "^4.5.1",
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.2.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core"
    ]
  }
}
